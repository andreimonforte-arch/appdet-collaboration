<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/rounded_input"
        android:layout_marginTop="16dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_facebook"
            android:layout_marginEnd="12dp"
            android:contentDescription="Facebook icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign up with Facebook"
            android:textSize="16sp"
            android:textColor="#333333"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Social Login: Google -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/rounded_input"
        android:layout_marginTop="16dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_google_empty_24dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="Google icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign up with Google"
            android:textSize="16sp"
            android:textColor="#333333"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp">

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#E0E0E0" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="or continue manually" android:textColor="#999999" android:layout_marginHorizontal="16dp" />
        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#E0E0E0" />
    </LinearLayout>

    <!-- Email -->
    <EditText
        android:id="@+id/etUsernameGE4"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Enter your email here"
        android:textColor="#333333"
        android:textColorHint="#999999"
        android:inputType="textEmailAddress"
        android:paddingHorizontal="20dp"
        android:background="@drawable/rounded_input"
        android:layout_marginBottom="12dp" />

    <!-- Password with toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@drawable/rounded_input"
        android:layout_marginBottom="24dp">

        <EditText
            android:id="@+id/etPasswordGE4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="Password"
            android:textColor="#333333"
            android:textColorHint="#999999"
            android:inputType="textPassword"
            android:paddingHorizontal="20dp"
            android:background="@null" />

        <ImageButton
            android:id="@+id/btnTogglePasswordGE4"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:src="@drawable/ic_eye_24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:contentDescription="Toggle password visibility" />
    </LinearLayout>

    <!-- Login Button -->
    <Button
        android:id="@+id/btnLoginGE4"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        app:cornerRadius="28dp"
        android:backgroundTint="#F26522"
        android:text="Sign in"
        android:textAllCaps="false"
        android:textColor="#F8F9FA"
        android:textSize="16sp" />

    <!-- Result Message -->
    <TextView
        android:id="@+id/tvResultGE4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- Forgot Password -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forgot password?"
        android:textColor="#666666"
        android:layout_marginTop="16dp" />

    <!-- Sign Up Link -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Don't have an account yet? Sign up"
        android:textColor="#666666"
        android:layout_marginTop="8dp" />

</LinearLayout>
