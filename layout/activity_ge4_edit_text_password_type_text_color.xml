<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp"
    android:background="#FFFFFF">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/rounded_input"
        android:layout_marginTop="16dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_facebook"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign up with Facebook"
            android:textSize="16sp"
            android:textColor="#333333"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Social Login: Google -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/rounded_input"
        android:layout_marginTop="16dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_google_empty_24dp"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign up with Google"
            android:textSize="16sp"
            android:textColor="#333333"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp">

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#E0E0E0" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="or continue manually" android:textColor="#999999" android:layout_marginHorizontal="16dp" />
        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#E0E0E0" />
    </LinearLayout>

    <!-- First Name -->
    <EditText
        android:id="@+id/etFirstNameGE4"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="First name"
        android:textColor="#333333"
        android:textColorHint="#999999"
        android:paddingHorizontal="20dp"
        android:background="@drawable/rounded_input"
        android:layout_marginBottom="12dp" />

    <!-- Last Name -->
    <EditText
        android:id="@+id/etLastNameGE4"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Last name"
        android:textColor="#333333"
        android:textColorHint="#999999"
        android:paddingHorizontal="20dp"
        android:background="@drawable/rounded_input"
        android:layout_marginBottom="12dp" />

    <!-- Email -->
    <EditText
        android:id="@+id/etUsernameGE4"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Enter your email here"
        android:textColor="#333333"
        android:textColorHint="#999999"
        android:inputType="textEmailAddress"
        android:paddingHorizontal="20dp"
        android:background="@drawable/rounded_input"
        android:layout_marginBottom="12dp" />

    <!-- Password with Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@drawable/rounded_input"
        android:layout_marginBottom="12dp">

        <EditText
            android:id="@+id/etPasswordGE4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="Password"
            android:textColor="#333333"
            android:textColorHint="#999999"
            android:inputType="textPassword"
            android:paddingHorizontal="20dp"
            android:background="@null" />

        <ImageButton
            android:id="@+id/btnTogglePasswordGE4"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:src="@drawable/ic_eye_24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp" />
    </LinearLayout>

    <!-- Repeat Password with Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@drawable/rounded_input"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/etRepeatPasswordGE4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="Repeat password"
            android:textColor="#333333"
            android:textColorHint="#999999"
            android:inputType="textPassword"
            android:paddingHorizontal="20dp"
            android:background="@null" />

        <ImageButton
            android:id="@+id/btnToggleRepeatGE4"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:src="@drawable/ic_eye_off_24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp" />
    </LinearLayout>

    <!-- Result Text -->
    <TextView
        android:id="@+id/tvResultGE4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- Create Account Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnLoginGE4"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Create account"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="#333333"
        android:background="@drawable/rounded_button_orange"
        android:layout_marginBottom="16dp" />

    <!-- Sign In Link -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Already have an account? Sign in"
        android:textColor="#666666"
        android:textSize="14sp" />

</LinearLayout>
